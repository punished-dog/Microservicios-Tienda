{
  "info": {
    "name": "Tienda Microservicios",
    "_postman_id": "tienda-microservicios-final",
    "description": "Colección completa para testear los microservicios. Orden recomendado: Eureka → Usuarios → Productos → Inventario → Pedidos → Pagos → Envios → Carrito → Resenas → Promociones → Soporte",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway", "value": "http://localhost:9090", "type": "string" },
    { "key": "eureka", "value": "http://localhost:8761", "type": "string" }
  ],
