      "name": "0. Eureka Server",
      "item": [
        {
          "name": "Dashboard (ver servicios registrados)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{eureka}}/eureka/apps", "host": ["{{eureka}}"], "path": ["eureka", "apps"] }
          }
        },
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{eureka}}/actuator/health", "host": ["{{eureka}}"], "path": ["actuator", "health"] }
