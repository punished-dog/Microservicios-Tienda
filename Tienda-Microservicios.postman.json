            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{eureka}}/eureka/apps/PEDIDOS", "host": ["{{eureka}}"], "path": ["eureka", "apps", "PEDIDOS"] }
