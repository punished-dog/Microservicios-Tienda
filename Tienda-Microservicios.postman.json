            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{eureka}}/eureka/apps/USUARIOS", "host": ["{{eureka}}"], "path": ["eureka", "apps", "USUARIOS"] }
